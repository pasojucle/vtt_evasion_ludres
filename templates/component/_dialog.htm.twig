<dialog data-controller="modal" data-modal-target="dialog" class="modal p-0 overflow-hidden bg-transparent">
    <div 
        data-modal-target="container"
        class="fixed inset-x-0 top-0 z-50 w-full md:w-1/3 md:left-1/3 bg-white dark:bg-slate-800 shadow-xl transition-transform duration-500 ease-out -translate-y-full"
    >
        <turbo-frame 
            id="modal_content" 
            data-modal-target="frame"
            data-action="turbo:frame-render->modal#open"
        ></turbo-frame>
    </div>
</dialog>