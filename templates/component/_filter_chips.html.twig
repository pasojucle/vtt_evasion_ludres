<div class="flex flex-wrap gap-2">
    {% for chip in chips %}
        <div class="flex items-center gap-2 text-slate-400 bg-slate-200 px-2 py-1 rounded-sm text-sm font-semibold">
            <div class="">
                {{ chip.label }}
            </div>
            <button 
                class="hover:text-slate-500"
                type="button" 
                data-action="filter#clear" 
                data-filter-name="{{ chip.name }}"
            >
                {{ ux_icon('lucide:x')}}
            </button>
        </div>
    {% endfor %}
</div>
