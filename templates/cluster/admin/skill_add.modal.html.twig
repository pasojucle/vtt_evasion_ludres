{% extends 'base_modal_stimulus.html.twig' %}
{% block modal_title %}Ajouter une compétence{% endblock %}
{% block body %}
    <div class="w-full m-0 py-2 px-4">
            <div class="form-group">
                {{ form_row(form.skillCategory) }}
                {{ form_row(form.level) }}
            </div>
            <div class="form-group" data-id="skills-container" data-form-modifier-target="container">
                {{ form_row(form.skill) }}
            </div>
        {{ form_errors(form) }}
    </div>
{% endblock %}
{% block action %}
    <button 
        type="submit"
        class="btn text-primary bg-neutral-200"
    >
        <i class="fas fa-check"></i> Ajouter
    </button>
{% endblock %}
