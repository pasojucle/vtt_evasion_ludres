{% extends 'base.html.twig' %}

{% block title %}Evaluations{% endblock %}

{% block body %}
<div class="wrapper">
    <div class="wrapper-title">
        <h1 class="font-bold text-3xl">Evaluations du groupe {{ cluster.title }}</h1>
        <div class="tool-group">
            <a href="{{ path('admin_bike_ride_cluster_show', {'bikeRide': cluster.bikeRide.id}) }}"
                class="btn btn-ico" title="Retour à la rando">
                <i class="fas fa-chevron-left"></i>
            </a>
        </div>
    </div>
    <div class="wrapper-body">
        {% if canEdit %}
            <a 
            class="btn btn-primary" 
            href="{{path('admin_cluster_skill_add', {'cluster': cluster.id})}}" 
            title="Ajouter"
            data-turbo-frame="modal_content"
        > 
            Ajouter
        </a>
        {% endif %}
        <ul id="skills-list-container" class="list-group">
            {% for skill in clusterSkills %}
                {% include 'cluster/admin/_skill_item.html.twig' %}
            {% endfor %}
        </ul>
    </div>
</div>
{% endblock %}