{% extends 'base.html.twig' %}

{% block title %}{{ bikeRide.title }}{% endblock %}

{% block body %}
 <div class="wrapper">
    {{ form_start(form) }}
    <div class="wrapper-title">
        <h1 class="font-bold text-3xl">{{ bikeRide.title }} - {{ bikeRide.period }}</h1>
        <span class="tools">
            <a href="{{ path('admin_bike_ride_cluster_show', {'bikeRide': bikeRide.id}) }}" class="btn btn-ico" title="Retour à la liste des sorties">
                <i class="fas fa-chevron-left"></i>
            </a>
        </span>
    </div>
    <div class="wrapper-body">
        <h3>Ajouter un nouveau participant</h3>
        <br>
        <div data-id="admin-session-add" data-form-modifier-target="container" class="row">
            <div class="col-md-6 col-xs-12">
                {{ form_widget(form.user)}}
            </div>
            <div class="col-md-6 col-xs-12">
                {{ form_widget(form.season)}}
            </div>
            <div class="col-md-12 col-xs-12">
                {{ form_row(form.cluster)}}
            </div>
            {% if form.practice is defined %}
                <div class="col-md-12 col-xs-12">
                    {{ form_row(form.practice) }}
                </div>
            {% endif %}
            <div data-id="session-bike-type" data-form-modifier-target="container" class="col-md-12 col-xs-12">
                {{ form_row(form.bikeType) }}
            </div>
        </div>
        {% include 'session/survey_responses.html.twig' %}
    </div>

    <div class="wrapper-footer">
        {{ form_row(form.submit) }}
        {{ form_errors(form) }}
    </div>
    {{ form_end(form) }}
{% endblock %}
