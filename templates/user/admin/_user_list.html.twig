<turbo-frame id="member-list">
    <div class="wrapper-title">
        <h1 class="font-bold text-3xl">Gestion des adhérents - <span class="badge badge-info">{{ paginator.total }}</span></h1>
        <div class="tool-group">
            <a 
                href="{{ path('wiki_show', {'directory': 'adhérents'})}}" 
                target="_blank" 
                title="wiki"
                class="text-foreground lg:text-muted lg:hover:text-foreground"
            >
                {{ ux_icon('lucide:circle-help',{ class: 'w-5 h-5' }) }}
            </a>
            {% include 'component/dropdown.html.twig' with {dropdown: settings}%}
            {% include 'component/dropdown.html.twig' with {dropdown: tools}%}
        </div>
    </div>
    {% include('user/admin/filters.html.twig') %}
    <div class="wrapper-body">
        {% include 'component/pagination.html.twig' with {'margin': 'bottom'} %}
        <ul>
            {% for user in users %}
                <li class="list-dropdown"> 
                    <a href="{{ path('admin_user', {'user': user.id})}}" data-turbo-frame="_top"
                        {% if user.level.colors is not null %}style="background-color: {{ user.level.colors.background }}"{% endif %}>
                        <div class="row">
                            <div class="col-md-4 col-xs-12">{{ user.member.fullName }}</div>
                            <div class="col-md-4 col-xs-12">
                                {% if user.lastLicence.isYearly is same as(false) %}
                                    {{ user.trialSessionsPresent }}/{{ user.testingBikeRides }} séances d'essai
                                {% endif %}
                            </div>
                            <div class="col-md-3 col-xs-10">
                                {{ user.level.title }}
                            </div>
                            <div class="col-md-1 col-xs-2">
                                {% if user.isBoardMember %}<i class="fa-solid fa-crown"></i>{% endif %}
                            </div>
                        </div>
                    </a> 
                    {% include 'component/dropdown.html.twig' with {dropdown: user.dropdown} %}
                </li>
            {% endfor %}
        </ul>
        {% include 'component/pagination.html.twig' with {'margin': 'top'} %}
    </div>
</turbo-frame>