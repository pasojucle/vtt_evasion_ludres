{% extends 'base.html.twig' %}

{% block title %}Participations{% endblock %}

{% block body %}
    <div class="wrapper">
        <div class="bg-primary text-white flex">
            <div class="px-3 py-2">
                <h1 class="font-bold text-3xl">Participation</h1>
            </div>
            <div class="ml-auto flex gap-2 items-center">
                <a 
                    href="{{ referer is defined ? referer : path('admin_user_list', {'filtered': 1}) }}" 
                    class="text-foreground lg:text-muted lg:hover:text-foreground" 
                    title="Retour à la liste des adhérents"
                >
                    {{ ux_icon('lucide:chevron-left', { class: 'w-6 h-6' }) }}
                </a>
                {% include 'component/dropdown.html.twig' with {dropdown: tools}%}
            </div>
        </div>
        <div class="wrapper-body">
            {% include('participation/admin/_frame_list.html.twig') %}
        </div>
    </div>
{% endblock %}