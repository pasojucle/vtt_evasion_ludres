{% extends 'base.html.twig' %}

{% block title %}Catégories de compétences{% endblock %}

{% block body %}
<div class="wrapper">
    <div class="wrapper-title">
        <h1 class="font-bold text-3xl">Gestion des catégories de compétences</h1>
        <div class="tool-group">
            <a href="{{ path('admin_skill_list') }}"
                class="btn btn-ico" title="Retour à la liste des compétences">
                <i class="fas fa-chevron-left"></i>
            </a>
        </div>
    </div>
    <div class="wrapper-body">
        <turbo-frame id="skill-category-list-frame">
            <a 
                class="btn btn-primary" 
                href="{{path('admin_skill_category_add', app.request.query.all)}}" 
                title="Ajouter"
                data-turbo-frame="modal_content"
            > 
                Ajouter
            </a>
            <ul class="list-group">
                {% for skillCategory in skillCategories %}
                    {{ include('skill_category/admin/_skill_category_item.html.twig', {skillCategory: skillCategory}) }}
                {% else %}
                    <li class="list-group-item">Aucune categorie trouvée.</li>
                {% endfor %}
            </ul>
        </turbo-frame>
    </div>
</div>
{% endblock %}