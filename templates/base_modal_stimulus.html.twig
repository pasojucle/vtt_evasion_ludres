<turbo-frame id="modal_content">
    {% import "component/_macros.html.twig" as utils %}
    {% if form is defined and form is not null %}
        {{ form_start(form)}}
    {% endif %}
    <div class="flex items-center justify-between p-4 md:p-5 border-b rounded-t dark:border-gray-600 border-gray-200 {{ utils.color_class(type.value) ??  utils.color_class('default')}}">
        <h3 class="!mt-0 !mb-0 text-xl font-semibold">
            {% block modal_title %}{% endblock %}
        </h3>
        <button 
            type="button"  
            data-action="click->modal#close" 
            class="end-2.5 text-slate-400 bg-transparent hover:bg-slate-200 hover:text-slate-900 rounded-lg text-sm w-8 h-8 ms-auto inline-flex justify-center items-center dark:hover:bg-slate-600 dark:hover:text-white" 
            data-modal-hide="authentication-modal">
            <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                <path stroke="currentColor" strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
            </svg>
            <span class="sr-only">Fermer</span>
        </button>
    </div>
    <div class="p-4 md:p-5 space-y-4">
        {% block body %}{% endblock %}
    </div>
    {% if block('action') is not empty %}
        <div class="p-4 md:p-5 grid grid-cols-1 md:grid-cols-2 gap-3 border-t dark:border-gray-600 border-gray-200 mt-3">
            <button type="button" data-action="click->modal#close" class="btn">Annuler</button>
            {% block action %}{% endblock %}
        </div>
    {% else %}
        <div class="p-4 md:p-5 grid grid-cols-1 md:grid-cols-2 gap-3 border-t dark:border-gray-600 border-gray-200 mt-3">
            <button type="button" data-action="click->modal#close" class="p-2 bg-slate-200 text-primary col-start-2">Fermer</button>
        </div>
    {% endif %}

    {% if form is defined and form is not null %}
        {{ form_end(form)}}
    {% endif %}
</turbo-frame>