{% extends 'base.html.twig' %}

{% set title = (bikeRide is null) ? 'Ajouter une sortie' : 'Modifier une sortie' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
    
    <div class="wrapper">
        {{ form_start(form) }}
        <div class="wrapper-title">
            <h1>{{ title }}</h1>
            <span class="tools">
                <a href="{{ path('admin_bike_rides', bike_rides_filters) }}" class="btn btn-ico" title="Retour à la liste des sorties"><i class="fas fa-chevron-left"></i></a>
            </span>
        </div>
        <div id="bike_ride_container" class="wrapper-body">
                {{ form_row(form.bikeRideType) }}
                {{ form_row(form.bikeRideTypeChanged) }}
                {{ form_row(form.title) }}
                {{ form_row(form.content) }}
                <div class="form-group">
                    <div class="form-group-file">
                        {{ form_row(form.file) }}
                        <div class="">
                            <img class="user-picture" src="{{ bikeRide.filename }}" alt="{{ bikeRide.title }}">   
                        </div>
                    </div>
                    {% if form.rulesFile is defined %}
                        <div class="form-group form-group-file form-group-inline" data-ratio="1.41">
                            <object class="sizing"  type="application/pdf" data="{{ bikeRide.rules }}">
                                <p>Le fichier PDF ne peut pas être affiché avec ce navigateur.</p>
                            </object>
                            {{ form_row(form.rulesFile) }}
                        </div>
                    {% endif %}
                    {% if form.rulesFileThumbnail is defined %}
                        <div class="form-group form-group-file form-group-inline" data-ratio="1.41">
                            <img class="user-picture" src="{{ bikeRide.rulesThumbnail }}" alt="{{ bikeRide.title }}">   
                            {{ form_row(form.rulesFileThumbnail) }}
                        </div>
                    {% endif %}
                    {% if form.securityGuidelinesFile is defined %}
                        <div class="form-group form-group-file form-group-inline" data-ratio="1.41">
                            <object class="sizing" type="application/pdf" data="{{ bikeRide.securityGuidelines }}">
                                <p>Le fichier PDF ne peut pas être affiché avec ce navigateur.</p>
                            </object>
                            {{ form_row(form.securityGuidelinesFile) }}
                        </div>
                    {% endif %}
                    {% if form.securityGuidelinesFileThumbnail is defined %}
                        <div class="form-group form-group-file form-group-inline" data-ratio="1.41">
                            <img class="user-picture" src="{{ bikeRide.securityGuidelinesThumbnail }}" alt="{{ bikeRide.title }}">   
                            {{ form_row(form.securityGuidelinesFileThumbnail) }}
                        </div>
                    {% endif %}
                    <b>{{ form_label(form.bikeRideTracks) }}</b>
                    <ul id="{{ form.bikeRideTracks.vars.name }}" class="collection_container"
                    data-index="{{ form.bikeRideTracks|length > 0 ? form.bikeRideTracks|last.vars.name + 1 : 0 }}" 
                    data-prototype="{{ form_widget(form.bikeRideTracks.vars.prototype)|e('html_attr') }}">
                        {% for item in form.bikeRideTracks %}
                            <li>{{ form_widget(item) }}</li>
                        {% endfor %}
                    </ul>
                    <div>
                        <button type="button" class="btn btn-success add-bike-ride-track" data-collection-holder-class="{{ form.bikeRideTracks.vars.name }}">
                        <i class="fas fa-plus-circle"></i> Ajouter un fichier
                        </button>            
                    </div>
                </div>
                
            <div class="form-group">
                {{ form_row(form.private) }}
            </div>
            <div class="form-group">
                {{ form_row(form.notify) }}
            </div>
            {% if form.registrationEnabled is defined %}
                <div class="form-group">
                    {{ form_row(form.registrationEnabled) }}
                </div>
            {% endif %}
            <div class="form-group">
                {{ form_row(form.startAt) }}
                {{ form_row(form.endAt) }}
            </div>
            <div class="form-group">
                {{ form_row(form.displayDuration) }}
                {{ form_row(form.closingDuration) }}
            </div>
            {% if form.registrationClosedMessage is defined %}
                {{ form_row(form.registrationClosedMessage) }}
            {% endif %}
            <br>
            <div id="bikeRideRestriction">
                {% for restriction in form.restriction %}
                    <div class="form-group radio-group">{{ form_widget(restriction) }} {{ form_label(restriction) }}</div>
                    {% if restriction.vars.value == constant('App\\Form\\Admin\\BikeRideType::RESTRICTION_TO_MEMBER_LIST') %}
                        <div class="row row-align-top">
                            <div class="form-group radio-group col-md-8">{{ form_row(form.users) }}</div>
                            <div class="form-group col-md-4">{{ form_row(form.levelFilter) }}</div>
                        </div>
                    {% endif %}
                    {% if restriction.vars.value == constant('App\\Form\\Admin\\BikeRideType::RESTRICTION_TO_RANGE_AGE') %}
                        <div class="form-group">
                            {{ form_row(form.minAge) }}
                            {{ form_row(form.maxAge) }}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
        {% if bikeRide.survey %}
            <div class="d-flex mx-20">
                <div><a class="btn btn-xs btn-primary" href="{{ path('admin_survey', {'survey': bikeRide.survey.id})}}"><i class="fa-solid fa-up-right-from-square"></i></a></div>
                <div class="ms-20">Sondage lié : {{ bikeRide.survey.title }}</div>
            </div>
        {% endif %}
        <div class="wrapper-footer">
            {{ form_row(form.save) }}
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
